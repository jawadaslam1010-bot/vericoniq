{
  "name": "contractly",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=@contractly/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter=@contractly/db run generate",
    "db:migrate": "pnpm --filter=@contractly/db run migrate",
    "db:studio": "pnpm --filter=@contractly/db run studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.4.5",
    "@types/node": "^20.14.2",
    "prettier": "^3.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
