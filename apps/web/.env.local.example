# ─── Supabase — ap-southeast-2 ONLY ────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co

# Anon/public key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon-key]

# Service role key — SERVER SIDE ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=[service-role-key]

# Transaction pooler connection string — Settings → Database → Connection string
# Use the "Transaction" pooler (port 6543), not "Session" pooler
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=[your-api-key]
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── AWS (Textract OCR fallback — ap-southeast-2 ONLY) ───────────────────────
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=[key]
AWS_SECRET_ACCESS_KEY=[secret]
# ARN of the ClamAV Lambda for malware scanning (Sprint 2+)
CLAMAV_LAMBDA_FUNCTION_ARN=arn:aws:lambda:ap-southeast-2:[account]:function:clamav-scan

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=[api-key]
FROM_EMAIL=notifications@contractly.com.au

# ─── Inngest (background jobs) ───────────────────────────────────────────────
INNGEST_EVENT_KEY=[event-key]
INNGEST_SIGNING_KEY=[signing-key]

# ─── Stripe (Sprint 10) ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=[sk_live_...]
STRIPE_WEBHOOK_SECRET=[whsec_...]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=[pk_live_...]

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Security ────────────────────────────────────────────────────────────────
# Rate limiting
RATE_LIMIT_AI_REQUESTS_PER_HOUR=100
